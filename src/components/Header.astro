---
// Site-wide navigation. Edit the links here to change the nav everywhere.
const path = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? path === '/' : path.startsWith(href);

const links = [
  { href: '/', label: 'Home' },
  { href: '/projects', label: 'Projects' },
  { href: '/blog', label: 'Blog' },
  { href: '/about', label: 'About' },
];
---
<header class="site-header">
  <nav class="container site-nav" aria-label="Primary">
    <a href="/" class="brand">fixmy.codes</a>
    <ul>
      {links.map((l) => (
        <li>
          <a href={l.href} aria-current={isActive(l.href) ? 'page' : undefined}>
            {l.label}
          </a>
        </li>
      ))}
    </ul>
  </nav>
</header>

<style>
  .site-header { border-bottom: 1px solid var(--color-border); }
  .site-nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding-top: 1rem;
    padding-bottom: 1rem;
  }
  .brand { font-weight: 650; color: var(--color-text); }
  .brand:hover { text-decoration: none; }
  .site-nav ul {
    display: flex;
    gap: 1.25rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }
  .site-nav a { color: var(--color-muted); }
  .site-nav a[aria-current='page'] { color: var(--color-text); font-weight: 600; }
</style>
