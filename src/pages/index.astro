---
// Home page: short intro, a few featured projects, recent posts.
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import PostCard from '../components/PostCard.astro';

const projects = (await getCollection('projects', ({ data }) => !data.draft))
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 3);

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---
<BaseLayout title="fixmy.codes" description="Personal site — projects and writing.">
  <section class="intro">
    <h1>fixmy.codes</h1>
    <p class="lead muted">
      Placeholder intro. A line or two about who this is and what you'll find here.
      Rewrite this.
    </p>
  </section>

  <section>
    <div class="section-head">
      <h2>Projects</h2>
      <a class="small" href="/projects">All projects &rarr;</a>
    </div>
    <div class="project-grid">
      {projects.map((p) => (
        <ProjectCard
          url={`/projects/${p.id}/`}
          title={p.data.title}
          summary={p.data.summary}
          status={p.data.status}
        />
      ))}
    </div>
  </section>

  <section>
    <div class="section-head">
      <h2>Writing</h2>
      <a class="small" href="/blog">All posts &rarr;</a>
    </div>
    {posts.map((post) => (
      <PostCard
        url={`/blog/${post.id}/`}
        title={post.data.title}
        description={post.data.description}
        pubDate={post.data.pubDate}
      />
    ))}
  </section>
</BaseLayout>

<style>
  .intro { margin-bottom: 2.5rem; }
  .lead { font-size: 1.1rem; }
  .section-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
  }
  .project-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.75rem;
    margin-bottom: 1rem;
  }
  @media (max-width: 34rem) {
    .project-grid { grid-template-columns: 1fr; }
  }
</style>
